---
import { imageMeta } from "../data/imageMeta";

type ImageMeta = typeof imageMeta;
type ImageKey = keyof ImageMeta;
type ImageName = ImageKey extends `${infer N}.${infer E}` ? N : never;
type ImageExtension = ImageKey extends `${infer N}.${infer E}` ? E : never;
type ImageFormat = "png" | "jpg" | "webp";

type PictureSource = {
  media?: string;
  type?: string;
  name: ImageName;
  format: ImageFormat;
};

type WidthKey = keyof ImageMeta[ImageKey]["widths"];

type Props = {
  alt?: string;
  class?: string;
  decoding?: "async" | "sync" | "auto";
  decorative?: boolean;
  ext: ImageExtension;
  fetchpriority?: "auto" | "high" | "low";
  id?: string;
  includeDefaultWebp?: boolean;
  lightbox?: boolean;
  loading?: "lazy" | "eager";
  name: ImageName;
  sizes?: string;
  sources?: PictureSource[];
  style?: string;
  widths?: number[];
};

const {
  alt = "",
  class: className = "",
  decoding = "async",
  decorative = false,
  ext,
  fetchpriority,
  id,
  includeDefaultWebp = true,
  lightbox = false,
  loading = "lazy",
  name,
  sizes = "(max-width: 50rem) 100vw, 1020px",
  sources = [],
  style,
  widths = [800, 1400, 2000]
} = Astro.props as Props;

const makeSrcSet = (base: ImageName, ext: ImageFormat) =>
  widths.map((width: number) => `/images/${base}-${width}w.${ext} ${width}w`).join(", ");

const makeSourceSrcSet = (source: PictureSource) =>
  makeSrcSet(source.name, source.format);

const defaultWidth = widths[Math.floor(widths.length / 2)];
const largestWidth = widths[widths.length - 1];
const defaultWidthKey = String(defaultWidth) as WidthKey;
const largestWidthKey = String(largestWidth) as WidthKey;
const imageKey = `${name}.${ext}` as ImageKey;
const meta = imageMeta[imageKey];
const sizeData = meta?.widths?.[defaultWidthKey];
const lightboxSize = meta?.widths?.[largestWidthKey];

const imageSrc = `/images/${name}-${defaultWidth}w.${ext}`;
const imageSrcSet = makeSrcSet(name, ext);
const webpSrcSet = makeSrcSet(name, "webp");
const lightboxHref = `/images/${name}-${largestWidth}w.${ext}`;
const lightboxSrcSet = makeSrcSet(name, ext);
---

{lightbox ? (
  <a
    class="pswp-item"
    href={lightboxHref}
    data-pswp-width={lightboxSize?.width}
    data-pswp-height={lightboxSize?.height}
    data-pswp-srcset={lightboxSrcSet}
    data-pswp-sizes={sizes}
    data-pswp-caption={alt || undefined}
  >
    <picture>
      {sources.map((source: PictureSource) => (
        <source
          media={source.media}
          type={source.type}
          srcset={makeSourceSrcSet(source)}
          sizes={sizes}
        />
      ))}
      {includeDefaultWebp && <source type="image/webp" srcset={webpSrcSet} sizes={sizes} />}
      <img
        src={imageSrc}
        srcset={imageSrcSet}
        sizes={sizes}
        width={sizeData?.width}
        height={sizeData?.height}
        alt={decorative ? "" : alt}
        aria-hidden={decorative ? "true" : undefined}
        class={className || undefined}
        id={id}
        style={style}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  </a>
) : (
  <picture>
    {sources.map((source: PictureSource) => (
      <source
        media={source.media}
        type={source.type}
        srcset={makeSourceSrcSet(source)}
        sizes={sizes}
      />
    ))}
    {includeDefaultWebp && <source type="image/webp" srcset={webpSrcSet} sizes={sizes} />}
    <img
      src={imageSrc}
      srcset={imageSrcSet}
      sizes={sizes}
      width={sizeData?.width}
      height={sizeData?.height}
      alt={decorative ? "" : alt}
      aria-hidden={decorative ? "true" : undefined}
      class={className || undefined}
      id={id}
      style={style}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />
  </picture>
)}
