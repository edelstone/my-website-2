---
import { nav } from "../data/nav";

const { pathname = "/" } = Astro.props;

function normalizePath(value: string | undefined) {
  if (!value || value === "/") return "/";
  return value.endsWith("/") ? value : `${value}/`;
}

const currentPath = normalizePath(pathname);
---

<nav class="nav constrain">
  {nav.map((item) => {
    const url = item.url;
    const isExact = currentPath === url;
    const isSection = currentPath.startsWith(url);

    return (
      <a href={url} aria-current={isExact || isSection ? "page" : undefined}>
        {item.label}
      </a>
    );
  })}
</nav>
