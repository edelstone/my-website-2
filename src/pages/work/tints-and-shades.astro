---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import Picture from "../../components/Picture.astro";
---

<BaseLayout title="Tint & Shade Generator" pathname="/work/tints-and-shades/" caseStudy={true}>
  <div class="case-study">
    <div class="case-study-header">
      <div class="case-study-header-content constrain">
        <h1><Icon name="tintsAndShades" />Tint &amp; Shade Generator</h1>
        <div class="case-study-header-nav">
          <a title="Previous" href="/work/texas-state/"><Icon name="previous" /></a>
          <a title="Next" href="/work/tock/"><Icon name="next" /></a>
        </div>
      </div>
    </div>
    <div class="case-study-writeup case-study-writeup-no-cards">
      <p>The <a href="https://maketintsandshades.com">Tint &amp; Shade Generator</a> is an open-source web app for accurately producing tints and shades from a given hex color in configurable increments. It has become one of the most popular color tools on the web, used by designers, developers, educators, and data analysts in over 180 countries.</p>
      <ul>
        <li><a href="https://maketintsandshades.com">Website</a></li>
        <li><a href="https://github.com/edelstone/tints-and-shades">Source code</a></li>
        <li><a href="https://www.figma.com/community/plugin/1580658889126377365/tint-shade-generator">Figma plugin</a></li>
      </ul>
    </div>
    <div class="case-study-visuals pswp-gallery">
      <Picture name="tints-shades-home" ext="png" alt="Product shot, home" class="case-study-visuals-browser" loading="eager" lightbox fetchpriority="high" />
      <Picture name="tints-shades-palettes" ext="png" alt="Product shot, generated color palettes" class="case-study-visuals-browser" lightbox />
      <Picture name="tints-shades-export" ext="png" alt="Product shot, export all colors" class="case-study-visuals-browser" lightbox />
    </div>
  </div>
</BaseLayout>
