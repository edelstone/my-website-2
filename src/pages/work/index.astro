---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Picture from "../../components/Picture.astro";

const thumbSizes = "(max-width: 40rem) calc(100vw - 2rem), (max-width: 60rem) calc((100vw - 4rem) / 2), 29rem";
---

<BaseLayout title="My portfolio" pathname="/work/">
  <div class="work">
    <div class="work-header">
      <h1>My portfolio</h1>
    </div>
    <div class="work-sections">
      <div class="work-section">
        <div class="work-header">
          <h2>Professional works</h2>
        </div>
        <div class="work-grid">
          <div class="work-row">
            <a href="gtreasury" class="work-card">
              <figure>
                <Picture
                  name="thumb-gt"
                  alt="GTreasury dashboard cashflow chart in action"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>GTreasury</h3>
                  <p>A component-based redesign and content strategy for a global financial firm.</p>
                </figcaption>
              </figure>
            </a>
            <a href="balto" class="work-card">
              <figure>
                <Picture
                  name="thumb-balto"
                  alt="Balto chat client with an active conversation"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Balto</h3>
                  <p>AI-assisted monitoring tools for coaches in high-volume contact centers.</p>
                </figcaption>
              </figure>
            </a>
          </div>
          <div class="work-row">
            <a href="kuali" class="work-card">
              <figure>
                <Picture
                  name="thumb-kuali"
                  alt="Kuali Research header and sidebar, highlighting co-branding"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Kuali</h3>
                  <p>A unifying experience for the world’s most crucial research projects.</p>
                </figcaption>
              </figure>
            </a>
            <a href="texas-state" class="work-card">
              <figure>
                <Picture
                  name="thumb-txst"
                  alt="Texas State color hierarchy and typography samples"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Texas State University</h3>
                  <p>An accessible digital identity to align and inspire a renowned Texas institution.</p>
                </figcaption>
              </figure>
            </a>
          </div>
        </div>
      </div>
      <div class="work-section">
        <div class="work-header">
          <h2>Open-source projects</h2>
        </div>
        <div class="work-grid">
          <div class="work-row">
            <a href="tints-and-shades" class="work-card">
              <figure>
                <Picture
                  name="thumb-tints-shades"
                  alt="Tint & Shade Generator palettes with complementary colors menu open"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Tint &amp; Shade Generator</h3>
                  <p>One of the most popular color tools on the web, with users in over 180 countries.</p>
                </figcaption>
              </figure>
            </a>
            <a href="tock" class="work-card">
              <figure>
                <Picture
                  name="thumb-tock"
                  alt="Tock app popover open below Mac menu bar with several common apps"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Tock</h3>
                  <p>A super-minimal timer with natural-language parsing and configurable tones.</p>
                </figcaption>
              </figure>
            </a>
          </div>
          <div class="work-row">
            <a href="material-palettes" class="work-card">
              <figure>
                <Picture
                  name="thumb-material"
                  alt="Material Palettes primary and secondary color arrays"
                  sizes={thumbSizes}
                />
                <figcaption>
                  <h3>Material Palettes</h3>
                  <p>Perfect color palettes based on Google’s design system methodology.</p>
                </figcaption>
              </figure>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
