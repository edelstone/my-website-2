---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Picture from "../../components/Picture.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { imageMeta } from "../../data/imageMeta";

type WorkEntry = CollectionEntry<"work">;
type ImageKey = keyof typeof imageMeta;
type ImageName = ImageKey extends `${infer N}.${string}` ? N : never;
type ImageExtension = ImageKey extends `${string}.${infer E}` ? E : never;

const thumbSizes =
  "(max-width: 40rem) calc(100vw - 2rem), (max-width: 60rem) calc((100vw - 4rem) / 2), 29rem";
const workEntries: WorkEntry[] = (await getCollection("work")).sort(
  (a: WorkEntry, b: WorkEntry) => a.data.order - b.data.order,
);

const sections = [
  { id: "professional", title: "Professional works" },
  { id: "open-source", title: "Open-source projects" },
];

function chunk<T>(items: T[], size: number): T[][] {
  return Array.from({ length: Math.ceil(items.length / size) }, (_, index) =>
    items.slice(index * size, index * size + size),
  );
}
---

<BaseLayout title="My portfolio" pathname="/work/">
  <div class="work">
    <div class="work-header">
      <h1>My portfolio</h1>
    </div>
    <div class="work-sections">
      {
        sections.map((section) => {
          const entries = workEntries.filter(
            (entry) => entry.data.section === section.id,
          );

          return (
            <div class="work-section">
              <div class="work-header">
                <h2>{section.title}</h2>
              </div>
              <div class="work-grid">
                {chunk(entries, 2).map((row) => (
                  <div class="work-row">
                    {row.map(({ data }) => (
                      <a href={`/work/${data.slug}/`} class="work-card">
                        <figure>
                          <Picture
                            name={data.thumb.name as ImageName}
                            ext={data.thumb.ext as ImageExtension}
                            alt={data.thumb.alt}
                            sizes={thumbSizes}
                          />
                          <figcaption>
                            <h3>{data.title}</h3>
                            <p>{data.summary}</p>
                          </figcaption>
                        </figure>
                      </a>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
