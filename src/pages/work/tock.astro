---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Pagination from "../../components/Pagination.astro";
import Picture from "../../components/Picture.astro";
---

<BaseLayout title="Tock" pathname="/work/tock/" caseStudy={true}>
  <div class="case-study">
    <div class="case-study-header">
      <div class="case-study-header-content constrain">
        <h1>Tock</h1>
        <div class="case-study-header-nav">
          <a title="Previous" href="/work/tints-and-shades/"><Pagination name="previous" /></a>
          <a title="Next" href="/work/material-palettes/"><Pagination name="next" /></a>
        </div>
      </div>
    </div>
    <div class="case-study-writeup case-study-writeup-no-cards">
      <p><a href="https://edelstone.github.io/tock/">Tock</a> is a super-minimal menu bar timer for macOS. Designed for speed and focus, it’s keyboard-driven, supports natural-language input, and intentionally centers on a single active timer to keep the interface uncluttered. Keyboard shortcuts, notification tones, repeat behavior, and volume are all configurable.</p>
      <ul>
        <li><a href="https://edelstone.github.io/tock/">Website</a></li>
        <li><a href="https://github.com/edelstone/tock">Source code</a></li>
        <li><a href="https://apps.apple.com/app/id6757497053">App store</a></li>
      </ul>
    </div>
    <div class="case-study-visuals pswp-gallery">
      <Picture name="tock-app" alt="Collage of various Tock popovers and settings menu" class="case-study-visuals-browser" loading="eager" lightbox fetchpriority="high" />
    </div>
  </div>
</BaseLayout>
