---
import BaseLayout from "../layouts/BaseLayout.astro";
import Picture from "../components/Picture.astro";
import { media } from "../data/media";
---

<BaseLayout title="Designer + neat person" pathname="/">
  <div class="homebase">
    <div class="homebase-visual">
      <Picture
        name="me-portrait"
        ext="jpg"
        decorative
        sizes="(max-width: 40rem) 100vw, 18rem"
        loading="eager"
        fetchpriority="high"
        sources={[
          {
            name: "me-landscape",
            format: "webp",
            type: "image/webp",
            media: media.portraitSwap
          },
          {
            name: "me-landscape",
            format: "jpg",
            type: "image/jpeg",
            media: media.portraitSwap
          }
        ]}
      />
    </div>
    <div class="homebase-text">
      <div class="homebase-text-header">
        <h1>Designer + neat person</h1>
      </div>
      <div class="homebase-text-intro">
        <p>I’m Michael Edelstone, a product designer focusing on utilitarian software and brands.</p>
        <p>You can do a few things here:</p>
      </div>
      <ul class="homebase-text-nav">
        <li><a href="/work/">View my portfolio</a></li>
        <li><a href="/about/">Learn about me</a></li>
        <li><a href="/contact/">Contact me</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
